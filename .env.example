# Docker Compose stack (demo, not for public-internet production).
# `compose.yaml` loads this file on every service (`env_file: .env.example`) — a clone
# is runnable with `docker compose up` with no copy step.
#
# For a private override: `cp .env.example .env.docker` (or any name), edit, and
# set `env_file` to that file on each service in `compose.yaml`.
#
# To run Symfony on the host (no containers), copy to `.env.local` and at minimum
# point DATABASE_URL at your MySQL (e.g. 127.0.0.1:3307 if MySQL is mapped from
# Docker), set APP_ENV=dev, and typically JWT_COOKIE_SECURE=1 for local HTTPS.

# MySQL
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=readloop
MYSQL_USER=appuser
MYSQL_PASSWORD=apppass

# Symfony (app service)
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=cb98666a47f6f1def01b72f9f9239ad4
APP_SHARE_DIR=var/share
DEFAULT_URI=http://localhost:8080
DATABASE_URL=mysql://appuser:apppass@mysql:3306/readloop?serverVersion=8.0&charset=utf8mb4
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=devpassphrase
# Plain HTTP on localhost — set to 1 when serving behind HTTPS.
JWT_COOKIE_SECURE=0
DB_HOST=mysql
DB_PORT=3306
# Set to 0 to skip loading AppFixtures on first boot.
SEED_FIXTURES=1

# phpMyAdmin
PMA_HOST=mysql
PMA_PORT=3306
PMA_USER=appuser
PMA_PASSWORD=apppass
UPLOAD_LIMIT=64M
