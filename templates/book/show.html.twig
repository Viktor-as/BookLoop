{% extends 'base.html.twig' %}

{% block title %}{{ book.title }} — BookLoop{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/catalog.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/book.css') }}">
{% endblock %}

{% block body %}
<div class="book-detail-back">
    <a href="{{ path('home') }}">← Back to book list</a>
</div>

<div class="book-detail-layout">
    <article class="book-detail-card catalog-card">
        <h1>{{ book.title }}</h1>
        <div class="catalog-meta">
            <div class="catalog-meta-item">
                <span class="catalog-meta-label">Authors</span>
                <span class="catalog-meta-value">{{ book.authors ?? '—' }}</span>
            </div>
            <div class="catalog-meta-item">
                <span class="catalog-meta-label">Categories</span>
                <span class="catalog-meta-value">{{ book.categories ?? '—' }}</span>
            </div>
        </div>
        {% if book.description %}
            <div class="book-detail-description">{{ book.description|nl2br }}</div>
        {% endif %}
        {% if member_has_active_borrow %}
            <span class="catalog-status self-borrowed">Already borrowed by you</span>
        {% elseif book.available %}
            <span class="catalog-status available">Available to borrow</span>
        {% else %}
            <span class="catalog-status unavailable">On loan</span>
        {% endif %}
    </article>

    <aside class="book-detail-card book-borrow-card">
        <h2>Borrow</h2>
        <div id="book-borrow-feedback" class="book-borrow-feedback is-hidden" role="status" aria-live="polite"></div>

        {% if app.user and member_has_active_borrow %}
            <p class="book-borrow-active">This book is already borrowed by you.</p>
        {% elseif not book.available %}
            <p class="book-borrow-unavailable">Sorry — this book is currently on loan. Please check back later.</p>
        {% elseif app.user %}
            <p class="book-borrow-hint">
                Maximum borrow length for this book: <strong>{{ quota.effectiveMaxBorrowDays }}</strong> day(s).<br>
                You may borrow up to <strong>{{ quota.remainingBorrowSlots }}</strong> more book(s) (limit {{ quota.effectiveBorrowLimit }}, {{ quota.activeBorrowCount }} active).
            </p>
            <form class="book-borrow-form" action="#" method="post" id="book-borrow-form" data-borrow-slug="{{ book.slug }}">
                <div>
                    <label for="borrow-days">Days to borrow</label>
                    <input type="number" id="borrow-days" name="days" min="1" max="{{ quota.effectiveMaxBorrowDays }}" value="{{ quota.effectiveMaxBorrowDays }}">
                </div>
                <button type="button" class="book-borrow-submit" id="book-borrow-submit">Borrow</button>
            </form>
        {% else %}
            <p class="book-borrow-guest">Please <a href="{{ path('register_page') }}">Register</a> / <a href="{{ path('login_page') }}">Login</a> to borrow this book</p>
        {% endif %}
    </aside>
</div>
{% endblock %}

{% block javascripts %}
    {% if app.user and book.available and not member_has_active_borrow %}
        <script type="module" src="{{ asset('js/book-borrow.js') }}" defer></script>
    {% endif %}
{% endblock %}
