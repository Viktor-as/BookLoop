<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}BookLoop{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>📚</text></svg>">
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <nav class="site-nav">
            <div>
                <a href="{{ path('home') }}" class="brand">📚 Library</a>
                <a href="{{ path('home') }}" {% if app.request.attributes.get('_route') == 'home' %}class="active"{% endif %}>Catalog</a>
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('admin_dashboard') }}" {% if app.request.pathInfo starts with '/admin' %}class="active"{% endif %}>Admin</a>
                {% endif %}
                {% if app.user %}
                    <a href="{{ path('borrowed_books') }}" {% if app.request.attributes.get('_route') == 'borrowed_books' %}class="active"{% endif %}>Borrowed books</a>
                {% endif %}
            </div>
            <div>
                {% if app.user %}
                    <span class="nav-user">{{ app.user.firstName }} {{ app.user.lastName }}</span>
                    <a href="{{ path('logout') }}" class="btn-logout">Logout</a>
                {% else %}
                    <a href="{{ path('login_page') }}" {% if app.request.attributes.get('_route') == 'login_page' %}class="active"{% endif %}>Login</a>
                    <a href="{{ path('register_page') }}" class="btn-primary" {% if app.request.attributes.get('_route') == 'register_page' %}class="active"{% endif %}>Register</a>
                {% endif %}
            </div>
        </nav>

        <main class="{% block main_class %}{% if app.request.pathInfo starts with '/admin' %}main--admin{% endif %}{% endblock %}">
            {% block flashes %}
                {% for type, messages in app.flashes(['success', 'error']) %}
                    {% for message in messages %}
                        <div class="flash {{ type }}">{{ message }}</div>
                    {% endfor %}
                {% endfor %}
            {% endblock %}

            {% block body %}{% endblock %}
        </main>

        {% block javascripts %}{% endblock %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    </body>
</html>
