{% extends 'admin/layout.html.twig' %}

{% block admin_title %}Users{% endblock %}

{% block admin_main %}
    <div class="admin-toolbar">
        <h1>Users</h1>
        <a href="{{ path('admin_users_new') }}" class="admin-btn admin-btn-primary">New user</a>
    </div>

    <div class="admin-table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Borrow limit</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for u in users %}
                    <tr>
                        <td>{{ u.id }}</td>
                        <td>{{ u.firstName }} {{ u.lastName }}</td>
                        <td>{{ u.email }}</td>
                        <td>{{ u.role }}</td>
                        <td>{{ u.borrowLimit ?? '—' }}</td>
                        <td class="admin-table-actions">
                            <a href="{{ path('admin_users_edit', {id: u.id}) }}" class="admin-btn admin-btn-secondary">Edit</a>
                            <form method="post" action="{{ path('admin_users_delete', {id: u.id}) }}" onsubmit="return confirm('Delete this user?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ u.id) }}">
                                <button type="submit" class="admin-btn admin-btn-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="6">No users yet.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
