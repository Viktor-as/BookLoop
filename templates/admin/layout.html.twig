{% extends 'base.html.twig' %}

{% block title %}{% block admin_title %}Admin{% endblock %} · BookLoop{% endblock %}

{% block main_class %}main--admin{% endblock %}

{% block flashes %}{# Flashes are shown inside .admin-main so they sit with admin content. #}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
{% endblock %}

{% block body %}
<div class="admin-layout">
    <aside class="admin-sidebar" aria-label="Admin navigation">
        <div class="admin-sidebar-title">Menu</div>
        <nav>
            <a href="{{ path('admin_dashboard') }}" class="{{ app.request.attributes.get('_route') == 'admin_dashboard' ? 'active' : '' }}">Dashboard</a>
            <a href="{{ path('admin_authors_index') }}" class="{{ app.request.attributes.get('_route') starts with 'admin_authors' ? 'active' : '' }}">Authors</a>
            <a href="{{ path('admin_categories_index') }}" class="{{ app.request.attributes.get('_route') starts with 'admin_categories' ? 'active' : '' }}">Categories</a>
            <a href="{{ path('admin_books_index') }}" class="{{ app.request.attributes.get('_route') starts with 'admin_books' ? 'active' : '' }}">Books</a>
            <a href="{{ path('admin_settings_index') }}" class="{{ app.request.attributes.get('_route') starts with 'admin_settings' ? 'active' : '' }}">Settings</a>
            <a href="{{ path('admin_users_index') }}" class="{{ app.request.attributes.get('_route') starts with 'admin_users' ? 'active' : '' }}">Users</a>
        </nav>
    </aside>
    <div class="admin-main">
        <div class="admin-flashes" aria-live="polite">
            {% for type, messages in app.flashes(['success', 'error']) %}
                {% for message in messages %}
                    <div class="flash {{ type }} admin-flash" role="status">{{ message }}</div>
                {% endfor %}
            {% endfor %}
        </div>
        {% block admin_main %}{% endblock %}
    </div>
</div>
{% endblock %}
